OLLAMA_MODEL=gemma4:e4b
OLLAMA_HOST=http://localhost:11434
TAVILY_API_KEY=
MAX_INGEST_CHARS=40000

# Multi-database root. Each database is an isolated subtree:
#   $DATA_ROOT/<db>/{raw,chunks,index,wiki}
# Users + per-user DB allowlists live in $DATA_ROOT/users.json (bcrypt hashes).
DATA_ROOT=data

# Deep chat (Chat → Deep mode)
CHAT_MIN_SEARCHES=3
CHAT_MIN_WORDS=300
CHAT_MIN_SOURCES=2
CHAT_MAX_ITERATIONS=25
CHAT_NUDGE_AT=10
CHAT_LLM_TIMEOUT=180

# Deep researcher (Research page)
RESEARCH_MIN_SEARCHES=6
RESEARCH_MIN_WORDS=600
RESEARCH_MIN_URLS=4
RESEARCH_MAX_ITERATIONS=40
RESEARCH_NUDGE_AT=18
RESEARCH_PARALLELISM=4
RESEARCH_LLM_TIMEOUT=300
